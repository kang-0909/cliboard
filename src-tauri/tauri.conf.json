{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cliboard",
  "mainBinaryName": "Cliboard",
  "version": "0.1.1",
  "identifier": "io.github.kang0909.cliboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Cliboard",
        "width": 748,
        "height": 548,
        "minWidth": 620,
        "minHeight": 430,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "backgroundThrottling": "disabled",
        "alwaysOnTop": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
